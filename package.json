{
  "name": "dynalist-mcp",
  "version": "0.2.4",
  "description": "MCP server for Dynalist.io - read, write, search, and organize outliner content",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "inspector": "bunx @modelcontextprotocol/inspector bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ scripts/",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "check": "bun run typecheck && bun run lint && bun test && bun run generate-docs",
    "generate-docs": "bun scripts/generate-docs.ts",
    "bundle": "bash scripts/bundle.sh",
    "release": "bash scripts/release.sh"
  },
  "keywords": ["mcp", "dynalist", "outliner", "model-context-protocol"],
  "author": "jayden-navarro",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^20.14.0",
    "eslint": "^10.0.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.0"
  }
}
